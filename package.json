{
  "name": "root",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/amplify-auth-hooks.git"
  },
  "scripts": {
    "postinstall": "biome migrate --write",
    "build": "turbo run build --filter=!./examples/* --filter=!*props-docs",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "check": "turbo run check",
    "check:packagejson": "turbo run check:packagejson",
    "test": "turbo run test:unit --filter=!./examples/* --filter=!*props-docs",
    "clean": "turbo run clean --filter=!./examples/* --filter=!*props-docs",
    "ncu": "mise run ncu"
  },
  "dependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@biomejs/biome": "2.4.6",
    "@fast-check/vitest": "0.3.0",
    "@storybook/addon-docs": "10.3.0",
    "@storybook/addon-links": "10.3.0",
    "@storybook/addon-vitest": "10.3.0",
    "@storybook/react-vite": "10.3.0",
    "@types/node": "25.4.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "jest-extended": "7.0.0",
    "playwright": "1.58.2",
    "rolldown": "1.0.0-rc.10",
    "storybook": "10.3.0",
    "terser": "5.46.1",
    "turbo": "2.8.19",
    "typescript": "5.9.3",
    "unplugin-isolated-decl": "0.15.7",
    "vite": "8.0.1",
    "vitest": "4.1.0"
  },
  "packageManager": "pnpm@10.32.1"
}
