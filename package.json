{
  "name": "root",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gahojin/amplify-auth-hooks.git"
  },
  "scripts": {
    "prepare": "biome migrate --write",
    "build": "turbo run build --filter=!./examples/* --filter=!*props-docs",
    "lint": "turbo run lint",
    "lint:ci": "turbo run lint:ci",
    "check": "turbo run check",
    "test": "turbo run test:unit --filter=!./examples/* --filter=!*props-docs",
    "clean": "turbo run clean --filter=!./examples/* --filter=!*props-docs",
    "ncu": "mise run ncu"
  },
  "dependencies": {
    "@biomejs/biome": "2.5.1",
    "@fast-check/vitest": "0.4.1",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@types/node": "25.9.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "playwright": "1.61.1",
    "storybook": "10.4.6",
    "turbo": "2.9.18",
    "typescript": "6.0.3",
    "unplugin-dts": "1.0.2",
    "vite": "8.1.0",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.6.0"
}
